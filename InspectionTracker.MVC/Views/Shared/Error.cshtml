@model ErrorViewModel
@{
    ViewData["Title"] = "Something went wrong";
}

<h1 class="text-danger">Oops! Something went wrong.</h1>

<p>
    We're sorry — something unexpected happened while processing your request.
    Our team has been notified and is looking into it.
</p>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}

<p>
    Please try again later or return to the <a href="/">home page</a>.
</p>
